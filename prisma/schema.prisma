generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Costume {
  id            String         @id @default(cuid())
  nom           String
  epoque        Epoque
  description   String?
  taille        String
  couleur       String
  matiere       String?
  etat          Etat           @default(BON)
  quantiteTotal Int            @default(1)
  quantiteDispo Int            @default(1)
  emplacement   String?
  proprietaire  String         @default("")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  prets         Pret[]
  images        CostumeImage[]
}

model CostumeImage {
  id        String   @id @default(cuid())
  costumeId String
  costume   Costume  @relation(fields: [costumeId], references: [id], onDelete: Cascade)
  url       String
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
}

model Pret {
  id               String     @id @default(cuid())
  costumeId        String
  costume          Costume    @relation(fields: [costumeId], references: [id])
  emprunteur       String
  dateDebut        DateTime   @default(now())
  dateRetourPrevue DateTime?
  dateRetourReelle DateTime?
  statut           StatutPret @default(EN_COURS)
  notes            String?
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  nom            String
  role           Role
  createdAt      DateTime  @default(now())
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum Epoque {
  AVANT_1900
  ANTIQUITE
  MOYEN_AGE
  RENAISSANCE
  E17EME
  E18EME
  E1800_1850
  E1850_1900
  E1900_1910
  E1910_1920
  E1920_1930
  E1930_1940
  E1940_1950
  E1950_1960
  E1960_1970
  E1970_1980
  E1980_1990
  E1990_2000
  E2000_2010
  E2010_2020
  E2020_PRESENT
  INCLASSABLE
}

enum Etat {
  NEUF
  BON
  USE
  A_REPARER
  A_NETTOYER
  A_FABRIQUER
}

enum StatutPret {
  EN_COURS
  RENDU
  EN_RETARD
}

enum Role {
  GESTIONNAIRE
  ADMIN
  // LECTEUR  ← désactivé pour l'instant
}